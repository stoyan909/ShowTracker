@using ShowTracker.ViewModel.ShowsViewModel
@model CreateShowViewModel

@{
    ViewData["Title"] = "Create Show";
}

<link rel="stylesheet" href="~/css/createShow.css" />

<div class="form-container">
    <h2>Create Show</h2>

    <form asp-action="CreateShow" method="post" enctype="multipart/form-data">

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" placeholder="Enter show title..." />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter description..."></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="SeasonNumber"></label>
            <input asp-for="SeasonNumber" type="number" class="form-control" min="1" />
            <span asp-validation-for="SeasonNumber" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label for="ShowPictureFile">Show Image</label>
            <input type="file" name="ShowPictureFile" class="form-control" accept="image/*" />
        </div>

        <div class="btn-group">
            <button type="submit" class="btn-submit">Create</button>
            <button type="button" class="btn-cancel" onclick="history.back()">Cancel</button>
        </div>
    </form>
</div>